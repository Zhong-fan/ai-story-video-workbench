# ChenFlow environment template.
# Copy this file to .env, then replace every value marked "replace-..." or "your-...".

# Required: language models used for writing and utility tasks.
CHENFLOW_LLM_MODE=openai
CHENFLOW_WRITER_MODEL=gpt-5.5
CHENFLOW_UTILITY_MODEL=gpt-5.4-mini
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional LLM transport tuning.
CHENFLOW_OPENAI_USE_SYSTEM_PROXY=false
CHENFLOW_LLM_USE_RESPONSES=true
CHENFLOW_LLM_STREAM_RESPONSES=true
CHENFLOW_LLM_REQUEST_TIMEOUT_SECONDS=120
CHENFLOW_LLM_MAX_ATTEMPTS=3
CHENFLOW_LLM_RETRY_MAX_SLEEP_SECONDS=120

# Required: semantic retrieval embeddings.
# OpenAI-compatible example:
CHENFLOW_EMBEDDING_MODEL=text-embedding-3-small
CHENFLOW_EMBEDDING_API_KEY=your-api-key
CHENFLOW_EMBEDDING_BASE_URL=https://api.openai.com/v1
# Local Ollama example:
# CHENFLOW_EMBEDDING_MODEL=bge-m3
# CHENFLOW_EMBEDDING_API_KEY=ollama
# CHENFLOW_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# Local Docker TEI example:
# CHENFLOW_EMBEDDING_MODEL=BAAI/bge-m3
# CHENFLOW_EMBEDDING_API_KEY=dummy
# CHENFLOW_EMBEDDING_BASE_URL=http://127.0.0.1:8090/v1

# Optional application binding. Keep 127.0.0.1 for local-only access.
CHENFLOW_APP_HOST=127.0.0.1
CHENFLOW_APP_PORT=8500

# Required: MySQL. These defaults match docker-compose.yml.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=chenflow_user
MYSQL_PASSWORD=chenflow_password
MYSQL_DATABASE=chenflow_workbench

# Required: login token signing and lifetime.
AUTH_SECRET=replace-this-with-a-long-random-secret
AUTH_EXP_HOURS=168

# Optional: Jimeng image and video generation.
JIMENG_ACCESS_KEY=replace-with-your-volcengine-access-key
JIMENG_SECRET_KEY=replace-with-your-volcengine-secret-key
JIMENG_ENDPOINT=https://visual.volcengineapi.com
JIMENG_REGION=cn-north-1
JIMENG_SERVICE=cv
JIMENG_VIDEO_REQ_KEY=jimeng_t2v_v30_1080p
JIMENG_VIDEO_I2V_REQ_KEY=jimeng_i2v_first_v30_1080
JIMENG_VIDEO_ASPECT_RATIO=16:9
JIMENG_VIDEO_FRAMES=121
JIMENG_IMAGE_REQ_KEY=jimeng_t2i_v40
JIMENG_IMAGE_WIDTH=1024
JIMENG_IMAGE_HEIGHT=1024
JIMENG_POLL_INTERVAL_SECONDS=10
JIMENG_POLL_TIMEOUT_SECONDS=900

# Optional fallback: OpenAI-compatible image generation.
# Used by the legacy video path when Jimeng credentials are blank.
CHENFLOW_IMAGE_API_KEY=
CHENFLOW_IMAGE_BASE_URL=
CHENFLOW_IMAGE_MODEL=
CHENFLOW_IMAGE_SIZE=1024x1024

# Optional TTS provider. Choose openai_compatible or volcengine_doubao.
CHENFLOW_TTS_PROVIDER=volcengine_doubao

# Required only when CHENFLOW_TTS_PROVIDER=openai_compatible.
CHENFLOW_TTS_API_KEY=
CHENFLOW_TTS_BASE_URL=
CHENFLOW_TTS_MODEL=
CHENFLOW_TTS_VOICE=

# Required only when CHENFLOW_TTS_PROVIDER=volcengine_doubao.
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_KEY=
VOLCENGINE_TTS_API_KEY=
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v3/tts/unidirectional
VOLCENGINE_TTS_SPEAKER=
VOLCENGINE_TTS_MODEL=
VOLCENGINE_TTS_SAMPLE_RATE=24000

# Optional when ffmpeg is already on PATH; required for final video composition.
CHENFLOW_FFMPEG_PATH=ffmpeg
